{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks",
      "settings": { "auth": "noauth", "udp": true }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "YOUR-SERVER-IP",
            "port": 55555,
            "users": [
              { "id": "YOUR-UUID-HERE" }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "serverName": "vkontakte.ru",
          "fingerprint": "chrome",
          "publicKey": "YOUR-PUBLIC-KEY",
          "shortId": "YOUR-SHORT-ID",
          "spiderX": "/qo9OnFhTWwwb2A6"
        },
        "xhttpSettings": {
          "host": "vkvideo.ru",
          "path": "/api/v1/update",
          "mode": "auto",
          "extra": {
            "mode": "auto",
            "xPaddingBytes": "100-1000"
          }
        }
      }
    },
    { "tag": "direct", "protocol": "freedom" }
  ],
  "routing": {
    "rules": [
      { "type": "field", "inboundTag": ["socks-in"], "outboundTag": "proxy" }
    ]
  }
}
