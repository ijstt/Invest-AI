# Окружение торгового процесса (Трек 2) на Raspberry Pi. Скопируйте в geo-futrader.env и заполните.
# Загружается systemd-юнитом через EnvironmentFile.

# --- Подключение к Postgres ГЛАВНОЙ машины по локальной сети ---
GEO_DB_HOST=192.168.0.196      # LAN-IP главной машины (проверьте `hostname -I` на главной)
GEO_DB_PORT=5432
GEO_DB_USER=geo
GEO_DB_PASSWORD=geo            # как в docker-compose.yml на главной (по умолчанию geo)
GEO_DB_NAME=geoanalytics

# --- Каданс торгового цикла ---
GEO_FUTRADER_INTRADAY_INTERVAL_SEC=600   # 10m бумажный цикл внутри сессии FORTS
GEO_FUTRADER_INTRADAY_INTERVAL=10m

# --- Опционально: Telegram для watchdog-алерта трейдера (без них — только лог) ---
# GEO_TELEGRAM_BOT_TOKEN=...
# GEO_TELEGRAM_CHAT_ID=...

# Ollama/LLM/NLP-модели трейдеру НЕ нужны — здесь их не задаём.
