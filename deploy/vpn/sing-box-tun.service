[Unit]
Description=sing-box TUN (перехват всего трафика → Xray SOCKS5)
After=xray.service
Requires=xray.service

[Service]
Type=simple
ExecStart=/opt/happ/bin/tun/sing-box run -c /usr/local/etc/sing-box/config.json
Restart=on-failure
RestartSec=5
# TUN требует сетевых привилегий
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE CAP_NET_RAW
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE CAP_NET_RAW
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
