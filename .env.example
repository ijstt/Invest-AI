# Скопируйте в .env и при необходимости поправьте значения.

# --- База данных (docker-compose поднимает её на localhost:5432) ---
GEO_DB_HOST=localhost
GEO_DB_PORT=5432
GEO_DB_USER=geo
GEO_DB_PASSWORD=geo
GEO_DB_NAME=geoanalytics

# --- LLM ---
# Провайдер тяжёлого синтеза: local (Ollama) | cloud (внешний API)
GEO_LLM_PROVIDER=local
GEO_OLLAMA_HOST=http://localhost:11434
GEO_LLM_MODEL=qwen2.5:7b-instruct
# Окно контекста LLM (токены). Дефолт Ollama 2048 обрезает длинный RAG-промпт.
GEO_LLM_NUM_CTX=8192
# Потолок длины ответа (токены). На CPU ~5 ток/с — без лимита синтез упирается в таймаут.
GEO_LLM_NUM_PREDICT=640
# Температура. Низкая для аналитики: дефолт Ollama ~0.7 даёт галлюцинации и языковые срывы.
GEO_LLM_TEMPERATURE=0.3
# Таймаут запроса к LLM, сек. На CPU холодный вызов (загрузка модели + длинный промпт).
GEO_LLM_TIMEOUT=240
# Сколько Ollama держит модель в RAM после запроса (иначе перезагрузка 5.5 ГБ каждый раз).
GEO_LLM_KEEP_ALIVE=30m
# Модель ask-пути (B): интент + нарратив. Единый 7B (качество, нет языковых срывов);
# грузится раз, держится keep_alive между интентом и нарративом — нет swap. Пик RAM ~9 ГБ.
# Для экономии (ценой качества) можно вернуть 3B: GEO_LLM_ROUTER_MODEL=qwen2.5:3b-instruct.
GEO_LLM_ROUTER_MODEL=qwen2.5:7b-instruct
GEO_LLM_ROUTER_NUM_CTX=8192
GEO_LLM_ROUTER_KEEP_ALIVE=30m
# Для cloud-fallback (опционально):
# GEO_CLOUD_API_KEY=
# GEO_CLOUD_BASE_URL=https://api.deepseek.com

# --- NLP-модели ---
GEO_EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Каталог кэша весов fastembed (~2 ГБ). КРИТИЧНО: дефолт fastembed = /tmp (эфемерен,
# чистится при ребуте → веса исчезают, семантика/RAG молча отключаются). Держим в data/.
GEO_EMBEDDING_CACHE_DIR=data/fastembed_cache
GEO_SENTIMENT_MODEL=blanchefort/rubert-base-cased-sentiment
# Дообученные модели (M4/M6.5/M7). Пусто — фолбэк (базовая модель / правила / формула).
# Путь может указывать на LoRA-адаптер ИЛИ на полностью дообученную модель (--full-finetune):
# nlp/sentiment.py детектит тип по наличию adapter_config.json.
# Sentiment подключён через дистилляцию LLM-учителя (Qwen2.5 → full-FT rubert-tiny2 на «золоте»,
# scripts/llm_label.py + scripts/train_lora.py --full-finetune): бьёт базу (acc vs gold 0.42→0.80).
# LoRA-поверх-frozen для sentiment НЕ работает (признаки blanchefort расходятся с метками учителя).
# GEO_SENTIMENT_ADAPTER_PATH=data/adapters/sentiment-ft-tiny2
# events/significance пока на правилах/формуле (LoRA-адаптеры слабее правил) — кандидат на M7.
# GEO_EVENT_ADAPTER_PATH=data/adapters/events-lora
# GEO_SIGNIFICANCE_ADAPTER_PATH=data/adapters/significance-lora

# F1/F2 (Волна 2): aspect-тональность и салиентность пары (статья, актив).
# Не задано → фолбэк: связи получают копию тональности статьи, салиентность NULL.
# GEO_ASPECT_SENTIMENT_ADAPTER_PATH=data/adapters/aspect-sentiment-v1b
# GEO_SALIENCY_ADAPTER_PATH=data/adapters/saliency-v1

# --- Значимость новости (M6) ---
# Веса формулы significance = w_type·тип + w_sent·|тональность| + w_link·связи (сумма 1.0).
GEO_SIG_W_TYPE=0.5
GEO_SIG_W_SENT=0.3
GEO_SIG_W_LINK=0.2
# Фильтр инжеста: незначимый шум (significance < порога, без активов, тип OTHER) не сохраняется.
GEO_MIN_SIGNIFICANCE=0.2
# TTL-ретеншн (geo prune): срок хранения новости (дней) растёт со значимостью от min до max.
GEO_RETENTION_MIN_DAYS=7
GEO_RETENTION_MAX_DAYS=365
# TTL для «сиротских» raw (отсеянный на инжесте шум без статьи) — чистится быстро.
GEO_RAW_RETENTION_DAYS=14

# --- Внешние источники (M4) ---
# Ключ FRED API (ФРС). Без него источник fred пропускается.
# Получить бесплатно: https://fred.stlouisfed.org/docs/api/api_key.html
# GEO_FRED_API_KEY=

# --- Алерты (M5.3) ---
# Окно поиска триггеров (часов) и пороги срабатывания.
GEO_ALERT_WINDOW_HOURS=24
GEO_ALERT_PRICE_PCT=5.0
# G1 (Волна 2): vol-нормализация price_move — триггер по z = |движение|/σ(EWMA).
# 0 — выключить (вернуться к фикс. GEO_ALERT_PRICE_PCT). MIN_PCT — floor от микродвижений.
GEO_ALERT_PRICE_ZSCORE=3.0
GEO_ALERT_PRICE_MIN_PCT=1.5
GEO_ALERT_NEG_COUNT=3
GEO_ALERT_NEG_RATIO=0.5
# Gate значимости (M6): алерты учитывают только новости со significance ≥ порога (0 — выкл).
GEO_ALERT_MIN_SIGNIFICANCE=0.35
# D1: типы событий, для которых new_event-алерт идёт ТОЛЬКО при наличии затронутого актива
# (asset-impact). Лечит шум: ~70% событий (в основном geopolitics) приходят без привязки и
# неоценимы. Список через запятую; пусто — гейт выключен.
GEO_ALERT_REQUIRE_IMPACT_TYPES=geopolitics
# D2: технические алерты (RSI-экстремумы, новый 52w-хай/лой, golden/death cross, всплеск
# объёма). Дедуп по дню. false — выключить.
GEO_ALERT_TECHNICAL_ENABLED=true
GEO_ALERT_RSI_LOW=30.0
GEO_ALERT_RSI_HIGH=70.0
GEO_ALERT_VOL_SPIKE_RATIO=3.0

# Исходы алертов (E4, Волна 1 v2.0): через сколько ТОРГОВЫХ дней скорить алерт и
# порог |движение − IMOEX| (%) для подтверждения (hit). Precision по типам алертов
# из этих исходов — глобальная метрика системы (еженедельный отчёт в Telegram).
GEO_ALERT_OUTCOME_HORIZON_DAYS=3
GEO_ALERT_OUTCOME_MOVE_PCT=2.0
# Telegram-уведомления (опционально). Задан токен + хотя бы один chat_id → канал активен.
# Токен у @BotFather. CHAT_ID — один id ИЛИ несколько через запятую для рассылки: "111,222"
# (каждый получатель должен сначала написать боту /start; id — через @userinfobot).
# GEO_TELEGRAM_BOT_TOKEN=
# GEO_TELEGRAM_CHAT_ID=
# SOCKS/HTTP-прокси ТОЛЬКО для исходящих в Telegram (api.telegram.org, t.me).
# Нужен, если Telegram заблокирован и нет общесистемного VPN (Happ/Xray SOCKS,
# см. deploy/pi/xray-config.json). Пусто — без прокси. socks5h — DNS через прокси.
# GEO_TELEGRAM_PROXY=socks5h://127.0.0.1:10808

# --- Планировщик (M6) ---
# Интервал между прогонами geo run-scheduler, сек. 300 = 5 мин (ниже ~60 не рекомендуется).
GEO_SCHEDULER_INTERVAL_SEC=300

# --- Бэктест ---
# Транзакционная издержка (комиссия + проскальзывание) за ОДНУ сторону сделки, базисные пункты
# (10 б.п. = 0.1%); round-trip = 2×. Делает оценку доходности честной.
GEO_BACKTEST_COST_BPS=5.0

# --- Прочее ---
GEO_LOG_LEVEL=INFO
# Глубина первичной загрузки истории котировок (дней)
GEO_HISTORY_DAYS=365
